{
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,
    "height": 30,
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "pulseaudio",
        "network",
        "battery",
        "custom/brightness",
        "clock"
    ],
    "hyprland/window": {
        "format": "{}",
        "max-length": 35,
        "rewrite": {
            "": "Hyprland"
        },
        "separate-outputs": true
    },
    "hyprland/workspaces": {
        "format": "{icon} ",
        "on-click": "activate",
        "format-icons": {
            "1": "\uf268",
            "2": "\uf113",
            "3": "\uf120"
        },
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": 3,
            "HDMI-A-1": 3
        }
    },
    "clock": {
        "format": "{:%I:%M %p}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>\n<big>{:%I:%M %p}</big>"
    },
    
    "custom/brightness": {
    "format": "{icon} {percent}%",
    "format-alt": "{percent}%",
    "on-click": "brightnessctl set +10%", 
    "on-scroll-up": "brightnessctl set +5%", 
    "on-scroll-down": "brightnessctl set 5%-", 
    "tooltip": false, 
    "format-icons": {
        "low": "´ŚŁ",    
        "medium": "´Ś×", 
        "high": "´Śč"    
    }
},

    
